# ============================================================
# MySQL 備份腳本環境變數設定範例
# 使用方式：cp .env.example .env，然後填入實際值
# 注意：.env 包含敏感資訊，請勿提交到版本控制
# ============================================================

# ── MySQL 連線設定 ──────────────────────────────────────────
MYSQL_CONTAINER=amanda-blog-mysql
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_root_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=33070

# ── AWS S3 設定 ─────────────────────────────────────────────
# 格式：s3://bucket-name/路徑
S3_BUCKET=s3://amanda-blog/mysql-backups

# AWS 區域，常用：
#   ap-northeast-1  東京
#   ap-southeast-1  新加坡
#   us-east-1       美東
S3_REGION=ap-northeast-1

# AWS CLI 設定檔名稱（~/.aws/credentials 裡的 profile）
# EC2 IAM Role 會自動提供憑證，請留空（不需要也不能填 Role 名稱）
# 只有使用 ~/.aws/credentials 的 named profile 時才填寫
AWS_PROFILE=

# ── 本地暫存目錄 ─────────────────────────────────────────────
# 備份檔暫存於此，上傳 S3 後自動刪除
BACKUP_DIR=/tmp/mysql-backups
